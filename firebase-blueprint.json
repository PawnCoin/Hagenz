{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A physical product for sale in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the product." },
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "A detailed description of the product." },
        "price": { "type": "number", "description": "The price of the product in USD." },
        "discountPrice": { "type": "number", "description": "Optional sale price." },
        "image": { "type": "string", "description": "The URL of the product image." },
        "category": { "type": "string", "description": "The category the product belongs to." },
        "videoUrl": { "type": "string", "description": "Optional URL for a product video." },
        "stock": { "type": "integer", "description": "The current stock level." },
        "specifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          },
          "description": "Technical specifications for the product."
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "e.g., Size, Color" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          },
          "description": "Available variants for the product."
        }
      },
      "required": ["name", "price", "image", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order containing items and shipping info.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "total": { "type": "number", "description": "The total order amount." },
        "tax": { "type": "number", "description": "The calculated tax for the order." },
        "shippingCost": { "type": "number", "description": "The shipping cost for the order." },
        "notes": { "type": "string", "description": "Optional customer notes for the order." },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"], "description": "The current status of the order." },
        "shippingAddress": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "zipCode": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "shippingAddress", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "loyaltyTier": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Platinum"], "description": "The user's loyalty tier based on $Pc holdings." },
        "pcBalance": { "type": "number", "description": "The user's current $Pc balance." },
        "walletAddress": { "type": "string", "description": "The user's verified wallet address." },
        "savedAddresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "fullName": { "type": "string" },
              "address": { "type": "string" },
              "city": { "type": "string" },
              "zipCode": { "type": "string" },
              "country": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          },
          "description": "A list of saved shipping addresses for the user."
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product being reviewed." },
        "userId": { "type": "string", "description": "The ID of the user who wrote the review." },
        "userName": { "type": "string", "description": "The name of the user who wrote the review." },
        "rating": { "type": "integer", "description": "The rating from 1 to 5." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item saved to a user's wishlist.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount code for the store.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The coupon code (e.g., WELCOME10)." },
        "type": { "type": "string", "enum": ["percentage", "fixed"], "description": "Type of discount." },
        "value": { "type": "number", "description": "Discount value (percentage or amount)." },
        "minPurchase": { "type": "number", "description": "Minimum purchase amount required." },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "type", "value"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A customer support request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "category": { "type": "string", "enum": ["order", "payment", "technical", "other"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "responses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "senderId": { "type": "string" },
              "senderName": { "type": "string" },
              "message": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" },
              "isAdmin": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["userId", "subject", "message", "status", "priority", "category", "createdAt"]
    },
    "ReturnRequest": {
      "title": "ReturnRequest",
      "description": "A request to return a product from an order.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "items", "reason", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "ticket", "system", "reward"] },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "GiftCard": {
      "title": "GiftCard",
      "description": "A digital gift card with a balance.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The unique gift card code." },
        "initialBalance": { "type": "number", "description": "The original value of the gift card." },
        "currentBalance": { "type": "number", "description": "The remaining balance." },
        "userId": { "type": "string", "description": "The ID of the user who purchased it." },
        "recipientEmail": { "type": "string", "description": "Optional recipient email." },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "initialBalance", "currentBalance", "isActive", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products available in the store."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all customer orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profile data."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product reviews."
    },
    "/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "Collection of user wishlist items."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Collection of store coupons."
    },
    "/tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Collection of customer support tickets."
    },
    "/returns/{returnId}": {
      "schema": "ReturnRequest",
      "description": "Collection of product return requests."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications."
    },
    "/giftcards/{giftcardId}": {
      "schema": "GiftCard",
      "description": "Collection of digital gift cards."
    }
  }
}

{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A physical product for sale in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the product." },
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "A detailed description of the product." },
        "price": { "type": "number", "description": "The price of the product in USD." },
        "image": { "type": "string", "description": "The URL of the product image." },
        "category": { "type": "string", "description": "The category the product belongs to." },
        "stock": { "type": "integer", "description": "The current stock level." },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "e.g., Size, Color" },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          },
          "description": "Available variants for the product."
        }
      },
      "required": ["name", "price", "image", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order containing items and shipping info.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "total": { "type": "number", "description": "The total order amount." },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"], "description": "The current status of the order." },
        "shippingAddress": {
          "type": "object",
          "properties": {
            "fullName": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" },
            "zipCode": { "type": "string" },
            "country": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "shippingAddress", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product being reviewed." },
        "userId": { "type": "string", "description": "The ID of the user who wrote the review." },
        "userName": { "type": "string", "description": "The name of the user who wrote the review." },
        "rating": { "type": "integer", "description": "The rating from 1 to 5." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item saved to a user's wishlist.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount code for the store.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The coupon code (e.g., WELCOME10)." },
        "type": { "type": "string", "enum": ["percentage", "fixed"], "description": "Type of discount." },
        "value": { "type": "number", "description": "Discount value (percentage or amount)." },
        "minPurchase": { "type": "number", "description": "Minimum purchase amount required." },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "type", "value"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products available in the store."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all customer orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profile data."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product reviews."
    },
    "/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "Collection of user wishlist items."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Collection of store coupons."
    }
  }
}
